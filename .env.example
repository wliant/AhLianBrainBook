# =============================================================================
# BrainBook Production Environment Configuration
# Copy this file to .env and update the values before deploying.
# =============================================================================

# -- PostgreSQL (external) ----------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/brainbook
SPRING_DATASOURCE_USERNAME=brainbook
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_postgres_password

# -- MinIO / S3 (external) ---------------------------------------------------
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_ACCESS_KEY=CHANGE_ME_access_key
MINIO_SECRET_KEY=CHANGE_ME_secret_key
MINIO_BUCKET=brainbook-attachments

# -- App (Spring Boot backend) -----------------------------------------------
# Host port the backend API is served on
APP_PORT=8080
# Comma-separated list of allowed CORS origins (must include the web URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Internal URL of the intelligence service (as seen by the backend container)
INTELLIGENCE_BASE_URL=http://intelligence-service:8001

# -- Intelligence Service (FastAPI + LangGraph) ------------------------------
# Host port the intelligence service is served on
INTELLIGENCE_PORT=8001
# LLM provider: "ollama" or "anthropic"
LLM_PROVIDER=ollama
# Log level for the intelligence service
LOG_LEVEL=INFO

# -- Ollama (used when LLM_PROVIDER=ollama) ----------------------------------
# URL of the Ollama API server
OLLAMA_BASE_URL=http://your-ollama-host:11434
# Default Ollama model for agents
OLLAMA_MODEL=deepseek-r1:32b
# Ollama base URL for embeddings (defaults to OLLAMA_BASE_URL if unset)
EMBEDDING_OLLAMA_BASE_URL=http://your-ollama-host:11434
# Ollama model used for embeddings
EMBEDDING_OLLAMA_MODEL=nomic-embed-text

# -- Anthropic (used when LLM_PROVIDER=anthropic) ----------------------------
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -- LLM Output ----------------------------------------------------------------
# Maximum output tokens for LLM responses (default: 4096)
LLM_MAX_TOKENS=4096

# -- AI Tools (search & retrieval) -------------------------------------------
# Tavily API key for web search (optional, falls back to DuckDuckGo)
TAVILY_API_KEY=
# Shared secret for internal API between intelligence service and Spring Boot
INTERNAL_API_KEY=

# -- Sandbox (Git repo cloning for Project Clusters) ------------------------
# Maximum size of a single cloned repo in MB
SANDBOX_MAX_REPO_SIZE_MB=10000
# Maximum total disk usage across all sandboxes in MB
SANDBOX_MAX_TOTAL_DISK_MB=307200
# Timeout for git clone operations in seconds
SANDBOX_CLONE_TIMEOUT_SEC=300
# Maximum number of concurrent clone operations
SANDBOX_MAX_CONCURRENT_CLONES=2
# Maximum number of sandboxes allowed
SANDBOX_MAX_COUNT=1000
# GitHub Personal Access Token for cloning private repos (optional)
GITHUB_PAT=

# -- Web (Next.js frontend) --------------------------------------------------
# Host port the frontend is served on
WEB_PORT=3000
# Public URL of the backend API (as seen by the browser)
NEXT_PUBLIC_API_URL=http://localhost:8080
